{
  "name": "@amartinr/pi-ts-prelint",
  "version": "0.0.1-alpha.1",
  "description": "Pre-write TypeScript linting for pi — blocks write/edit on .ts/.tsx files if tsc compilation fails",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "pi-package",
    "typescript",
    "lint",
    "pre-write",
    "tsc",
    "coding-agent"
  ],
  "author": "A. Martin <abel.martin.ruiz@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amartinr/pi-ts-prelint.git"
  },
  "bugs": {
    "url": "https://github.com/amartinr/pi-ts-prelint/issues"
  },
  "homepage": "https://github.com/amartinr/pi-ts-prelint",
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "diff": "^8.0.4",
    "typescript": "^6.0.3"
  },
  "pi": {
    "extensions": [
      "./dist"
    ]
  }
}
